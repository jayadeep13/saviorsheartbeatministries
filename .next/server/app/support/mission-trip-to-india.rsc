]]}],["$","div",null,{"className":"mt-8 border-t border-[#B51657]/15 pt-6","children":[["$","p",null,{"className":"font-[Playfair_Display] text-xl italic leading-relaxed text-[#1E1E22] md:text-2xl","children":"\"The things that you have heard from me... commit these to faithful men who will be able to teach others also.\""}],["$","p",null,{"className":"mt-3 font-accent text-[10px] font-bold uppercase tracking-[0.3em] text-[#B51657]","children":"2 Timothy 2:2"}]]}]]}]]}]}],["$","$L2","Serve Through Humanitarian Care",{"delay":180,"children":["$","article",null,{"className":"grid gap-8 border border-[#E8DDE2] bg-white p-6 shadow-[0_18px_60px_rgba(0,0,0,0.08)] lg:items-stretch lg:p-8 lg:grid-cols-[1.05fr_0.95fr]","children":[["$","div",null,{"className":"order-2 grid min-h-[430px] gap-4 sm:grid-cols-2 lg:min-h-full lg:grid-cols-1 lg:order-2","children":[["$","div","/out (2).webp",{"className":"relative min-h-[240px] overflow-hidden bg-[#12070C] shadow-[0_14px_42px_rgba(0,0,0,0.12)]","children":[["$","$L4",null,{"src":"/out (2).webp","alt":"Children ministry outreach","fill":true,"className":"object-cover transition-transform duration-700 hover:scale-105","sizes":"(min-width: 1024px) 500px, (min-width: 640px) 50vw, 100vw","priority":false}],["$","div",null,{"className":"absolute inset-0 bg-gradient-to-t from-black/45 via-black/5 to-transparent"}]]}],["$","div","/out (1).webp",{"className":"relative min-h-[240px] overflow-hidden bg-[#12070C] shadow-[0_14px_42px_rgba(0,0,0,0.12)]","children":[["$","$L4",null,{"src":"/out (1).webp","alt":"Widows care outreach","fill":true,"className":"object-cover transition-transform duration-700 hover:scale-105","sizes":"(min-width: 1024px) 500px, (min-width: 640px) 50vw, 100vw","priority":false}],["$","div",null,{"className":"absolute inset-0 bg-gradient-to-t from-black/45 via-black/5 to-transparent"}]]}]]}],["$","div",null,{"className":"order-1 flex h-full flex-col justify-between border-l-[6px] border-[#B51657] bg-[#FFFDF9] p-6 md:p-8 lg:order-1","children":[["$","div",null,{"children":[["$","div",null,{"className":"mb-7 flex items-center gap-4","children":[["$","div",null,{"className":"flex h-12 w-12 items-center justify-center bg-[#B51657] text-white","children":["$","$L3",null,{"iconNode":[["path",{"d":"M19.414 14.414C21 12.828 22 11.5 22 9.5a5.5 5.5 0 0 0-9.591-3.676.6.6 0 0 1-.818.001A5.5 5.5 0 0 0 2 9.5c0 2.3 1.5 4 3 5.5l5.535 5.362a2 2 0 0 0 2.879.052 2.12 2.12 0 0 0-.004-3 2.124 2.124 0 1 0 3-3 2.124 2.124 0 0 0 3.004 0 2 2 0 0 0 0-2.828l-1.881-1.882a2.41 2.41 0 0 0-3.409 0l-1.71 1.71a2 2 0 0 1-2.828 0 2 2 0 0 1 0-2.828l2.823-2.762","key":"17lmqv"}]],"className":"lucide-heart-handshake h-6 w-6","strokeWidth":1.8}]}],["$","div",null,{"children":[["$","p",null,{"className":"font-accent text-[10px] font-bold uppercase tracking-[0.3em] text-[#B51657]","children":"Compassion Ministry"}],["$","p",null,{"className":"mt-1 font-body text-sm font-semibold text-[#8A7D84]","children":["0",3]}]]}]]}],["$","h3",null,{"className":"font-[Playfair_Display] text-4xl font-bold leading-[1.03] text-[#1E1E22] md:text-5xl","children":"Serve Through Humanitarian Care"}],["$","p",null,{"className":"mt-4 font-[Playfair_Display] text-2xl italic leading-tight text-[#B51657] md:text-3xl","children":"Bring practical help with dignity and love."}],["$","div",null,{"className":"mt-7 space-y-5 font-body text-base leading-8 text-[#5F575E]","children":[["$","p","Alongside preaching and teaching, mission trips can include compassionate care for children, widows, families, and villages in need. Practical service opens doors for trust, encouragement, and the love of Christ to be seen in action.",{"children":"Alongside preaching and teaching, mission trips can include compassionate care for children, widows, families, and villages in need. Practical service opens doors for trust, encouragement, and the love of Christ to be seen in action."}],["$","p","Teams may help distribute food, clothing, school supplies, basic medical support, and relief items. They may also visit children, pray with widows, encourage families, and support local ministry projects that continue after the team returns home.",{"children":"Teams may help distribute food, clothing, school supplies, basic medical support, and relief items. They may also visit children, pray with widows, encourage families, and support local ministry projects that continue after the team returns home."}],["$","p","Every gift and every visit should carry dignity. The heart of the trip is to serve people as precious souls loved by God, not as projects, but as families made in His image.",{"children":"Every gift and every visit should carry dignity. The heart of the trip is to serve people as precious souls loved by God, not as projects, but as families made in His image."}]]}]]}],["$","div",null,{"className":"mt-8 border-t border-[#B51657]/15 pt-6","children":[["$","p",null,{"className":"font-[Playfair_Display] text-xl italic leading-relaxed text-[#1E1E22] md:text-2xl","children":"\"Whatever you did for one of the least of these brothers and sisters of mine, you did for me.\""}],["$","p",null,{"className":"mt-3 font-accent text-[10px] font-bold uppercase tracking-[0.3em] text-[#B51657]","children":"Matthew 25:40"}]]}]]}]]}]}]]}]]}]]}],["$","section",null,{"className":"border-t border-[#E8DDE2] bg-[#FDF8F2] py-20","children":["$","div",null,{"className":"mx-auto grid max-w-6xl gap-8 px-6 md:grid-cols-[0.75fr_1fr] md:items-center","children":[["$","$L2",null,{"dir":"left","children":[["$","p",null,{"className":"mb-4 font-accent text-[10px] font-bold uppercase tracking-[0.35em] text-[#B51657]","children":"Plan With Us"}],["$","h2",null,{"className":"font-[Playfair_Display] text-4xl font-bold leading-[1.03] text-[#1E1E22] md:text-5xl","children":"A mission trip begins with prayer, planning, and partnership."}]]}],["$","$L2",null,{"dir":"right","children":["$","div",null,{"className":"border border-[#E8DDE2] bg-white p-7 shadow-[0_14px_44px_rgba