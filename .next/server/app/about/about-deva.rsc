magazine which blesses Telugu readers around the globe."}],["$","p",null,{"children":"The ministry invites all who are moved by the Spirit to partner in prayer, financial support, or active service — so that together, we can continue to fulfill the Savior's Heartbeat for India."}]]}],["$","div",null,{"className":"mt-10 grid grid-cols-3 gap-4","children":[["$","div","Years of Ministry",{"className":"text-center p-4 bg-white rounded-2xl shadow-[0_2px_16px_rgba(0,0,0,0.06)] border border-gray-100","children":[["$","div",null,{"className":"font-display text-2xl text-crimson-500 font-semibold","children":"50+"}],["$","div",null,{"className":"text-onyx-500 text-[10px] uppercase font-bold tracking-wider mt-1","children":"Years of Ministry"}]]}],["$","div","Churches Built",{"className":"text-center p-4 bg-white rounded-2xl shadow-[0_2px_16px_rgba(0,0,0,0.06)] border border-gray-100","children":[["$","div",null,{"className":"font-display text-2xl text-crimson-500 font-semibold","children":"12"}],["$","div",null,{"className":"text-onyx-500 text-[10px] uppercase font-bold tracking-wider mt-1","children":"Churches Built"}]]}],["$","div","Children Cared For",{"className":"text-center p-4 bg-white rounded-2xl shadow-[0_2px_16px_rgba(0,0,0,0.06)] border border-gray-100","children":[["$","div",null,{"className":"font-display text-2xl text-crimson-500 font-semibold","children":"100+"}],["$","div",null,{"className":"text-onyx-500 text-[10px] uppercase font-bold tracking-wider mt-1","children":"Children Cared For"}]]}]]}]]}]]}]}]}],["$","section",null,{"className":"py-24 bg-black text-white overflow-hidden","children":["$","div",null,{"className":"max-w-6xl mx-auto px-6","children":["$","div",null,{"className":"grid lg:grid-cols-2 gap-16 items-center","children":[["$","$L2",null,{"dir":"left","children":["$","div",null,{"className":"space-y-8","children":[["$","div",null,{"children":[["$","p",null,{"className":"text-crimson-500 uppercase tracking-[0.4em] font-bold text-[10px] mb-4","c